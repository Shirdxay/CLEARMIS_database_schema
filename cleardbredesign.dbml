    //ає€.ає™ ає„ає»ає§а»Ђає®ає·ає­ає™ає—ає±ає‡а»ќає»ає”ає—аєµа»€а»„ає”а»‰аєўа»‰аєЅаєЎаєўаєІаєЎа»‚ає”аєЌаєЃає°аєЄаєґаєЃає­ає™ає•ає»ає§а»Ѓаєљаєљ
    visit_date date [not null, note:"visit dates"]
    visited_hh int [not null, note:"number of households visited during the garden visits in the month"]
    created_at timestamp [default: `now()`, note:"timestamp when the monthly data record was created"]
    updated_at timestamp [default: `now()`, note:"timestamp when the monthly data record was last updated"]
}

